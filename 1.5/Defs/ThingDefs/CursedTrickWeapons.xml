<Defs>

    <ThingDef ParentName="BaseHumanMakeableGun">
        <defName>PGG_WaveBlaster</defName>
        <label>wave blaster</label>
		<graphicData>
     		 <texPath>Things/Item/Equipment/WeaponRanged/WaveBlaster</texPath>
     		 <graphicClass>Graphic_Single</graphicClass>
    	</graphicData>
        <description>This experimental firearm crackles with barely contained energy, firing crescent waves at range. However, its true potential may lie in its ability to transform into a deadly Pulse Cleaver for close-quarters combat.</description>
        <techLevel>Spacer</techLevel>
        <soundInteract>Interact_ChargeLance</soundInteract>
        <tradeability>Sellable</tradeability>
        <destroyOnDrop>False</destroyOnDrop>
        <statBases>
            <WorkToMake>55000</WorkToMake>
            <Mass>3.0</Mass>
            <MarketValue>1200</MarketValue>
            <SellPriceFactor>0.5</SellPriceFactor>
            <AccuracyTouch>0.75</AccuracyTouch>
            <AccuracyShort>0.85</AccuracyShort>
            <AccuracyMedium>0.70</AccuracyMedium>
            <AccuracyLong>0.55</AccuracyLong>
            <RangedWeapon_Cooldown>1.8</RangedWeapon_Cooldown>
        </statBases>
        <weaponTags>
            <li>Gun</li>
        </weaponTags>
		<costList>
      		<Steel>50</Steel>
      		<ComponentIndustrial>3</ComponentIndustrial>
      		<PGG_CursedComponent>3</PGG_CursedComponent>
    	</costList>
    	<recipeMaker>
     		 <researchPrerequisite>PGG_EsotericWeaponry</researchPrerequisite>
      		<skillRequirements>
      		  <Crafting>8</Crafting>
      		</skillRequirements>
      	<displayPriority>420</displayPriority>
		<recipeUsers>
        <li>TableMachining</li>
      </recipeUsers>
    </recipeMaker>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>PGG_CrescentWaveProj</defaultProjectile>
                <warmupTime>1.5</warmupTime>
                <range>32</range>
                <burstShotCount>3</burstShotCount>
                <soundCast>Shot_ChargeBlaster</soundCast>
                <soundCastTail>GunTail_Heavy</soundCastTail>
                <muzzleFlashScale>12</muzzleFlashScale>
            </li>
        </verbs>    
        <comps>
            <li Class="Pesky.CompProperties_TransformWeapon">
                <weaponsToTransform>
                    <li>
                        <weapon>PGG_PulseCleaver</weapon>
                        <label>Transform to Cleaver</label>
                        <description>Activate the weapon's transformation sequence to shift into its Pulse Cleaver form.</description>
                        <ticksToTransformWeapon>60</ticksToTransformWeapon>
                    </li>
                </weaponsToTransform>
            </li>
            <li Class="Pesky.CompProperties_WeaponHediff">
                <hediffs>
                    <li>
                        <hediffToApply>PGG_VoidResonance</hediffToApply>
                        <hediffSeverity>1.0</hediffSeverity>
                        <removeWhenUnequipped>true</removeWhenUnequipped>
                        <applyOnUnequip>false</applyOnUnequip>
                    </li>
                </hediffs>
            </li>
        </comps>
    </ThingDef>

