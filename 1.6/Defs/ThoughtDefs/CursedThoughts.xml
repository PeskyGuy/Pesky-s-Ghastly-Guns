        <baseMoodEffect>-5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

<ThoughtDef>
    <defName>PGG_VoidResonanceThought</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <hediff>PGG_VoidResonance</hediff>
    <validWhileDespawned>true</validWhileDespawned>
    <stages>
      <li>
        <label>void resonance</label>
        <description>This weapon... it hums with an energy that isn't quite right. It makes my thoughts echo strangely, but I feel so light on my feet.</description>
        <baseMoodEffect>-10</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

<ThoughtDef>
    <defName>PGG_VoidAnchorThought</defName>
    <workerClass>ThoughtWorker_Hediff</workerClass>
    <hediff>PGG_VoidAnchor</hediff>
    <validWhileDespawned>true</validWhileDespawned>
    <stages>
      <li>
        <label>void anchor</label>
