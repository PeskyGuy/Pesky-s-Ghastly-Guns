      <skillRequirements><Crafting>6</Crafting></skillRequirements>
      <displayPriority>400</displayPriority>
    </recipeMaker>
    <weaponTags>
      <li>Gun</li>
      <li>PumpShotgun</li>
    </weaponTags>
    <weaponClasses>
      <li>ShortShots</li>
    </weaponClasses>
