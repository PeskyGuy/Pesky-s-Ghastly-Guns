  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>PGG_MementoMori</defName>
    <label>memento mori</label>
    <description>An eerily pristine revolver with a flawless black finish and intricate gold inlay. Despite its beauty, it radiates a subtle wrongness. The weapon seems to increase the wielder's accuracy at the cost of their mental stability.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/MementoMori</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <uiIconScale>1.4</uiIconScale>
    <soundInteract>Interact_Revolver</soundInteract>
    <statBases>
      <Mass>1.4</Mass>
      <AccuracyTouch>0.80</AccuracyTouch>
      <AccuracyShort>0.75</AccuracyShort>
      <AccuracyMedium>0.45</AccuracyMedium>
      <AccuracyLong>0.35</AccuracyLong>
      <RangedWeapon_Cooldown>1.6</RangedWeapon_Cooldown>
    </statBases>
    <weaponTags>
      <li>Gun</li>
      <li>Revolver</li>
    </weaponTags>
    <weaponClasses>
      <li>RangedHeavy</li>
    </weaponClasses>
    <costList>
      <Steel>30</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
      <Gold>10</Gold>
      <PGG_CursedComponent>3</PGG_CursedComponent>
    </costList>
    <recipeMaker>
      <researchPrerequisite>PGG_EsotericWeaponry</researchPrerequisite>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <displayPriority>400</displayPriority>
      <recipeUsers>
        <li>TableMachining</li>
      </recipeUsers>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_MementoMori</defaultProjectile>
        <warmupTime>0.3</warmupTime>
        <range>35</range>
        <soundCast>Shot_Revolver</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>12</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>grip</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>1.5</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>12</power>
        <cooldownTime>1.5</cooldownTime>
      </li>
    </tools>
    <comps>
      <li Class="Pesky.CompProperties_WeaponHediff">
        <hediffs>
          <li>
            <hediffToApply>PGG_ReapersHand</hediffToApply>
            <hediffSeverity>0.1</hediffSeverity>
            <removeWhenUnequipped>true</removeWhenUnequipped>
            <applyOnUnequip>false</applyOnUnequip>
          </li>
          <li>
            <hediffToApply>PGG_ReapersMadness</hediffToApply>
            <hediffSeverity>1.0</hediffSeverity>
            <removeWhenUnequipped>false</removeWhenUnequipped>
            <applyOnUnequip>true</applyOnUnequip>
          </li>
        </hediffs>
      </li>
    </comps>
